NODE_ENV=development
PORT=3001
LOG_LEVEL=info
CORS_ORIGIN=http://localhost:5173
VITE_APP_TITLE=锂电池企业智能诊断系统
VITE_API_BASE_URL=/api
PERSISTENCE_MODE=file
STORAGE_DIR=.runtime/platform
CACHE_TTL_SECONDS=300
CACHE_STALE_TTL_SECONDS=1800
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=120
ASYNC_TASK_CONCURRENCY=2
AGENT_BUDGET_TOTAL_TOKENS=16000
AGENT_BUDGET_MAX_STEPS=12
AGENT_RETRY_LIMIT=2
EXTERNAL_FETCH_TIMEOUT_MS=4000
EXTERNAL_FETCH_RETRY_COUNT=2
RAG_SOURCE_WHITELIST=sse.com.cn,szse.cn,bse.cn,cninfo.com.cn,eastmoney.com,dfcfw.com,stats.gov.cn,gov.cn,edu.cn
RAG_MAX_SOURCE_AGE_DAYS=60
HEALTHCHECK_INCLUDE_DETAILS=true
ENABLE_BACKGROUND_TASKS=true
# ========================================
# 必需配置（至少填写一个模型 API Key）
# ========================================

# 深度求索 (DeepSeek，可单独启用)
DEEPSEEK_API_KEY=your_deepseek_api_key
DEEPSEEK_BASE_URL=https://api.deepseek.com/v1

# 智谱 (GLM，可单独启用)
GLM_API_KEY=your_glm_api_key
GLM_BASE_URL=https://open.bigmodel.cn/api/paas/v4

# 阿里通义千问 (Qwen，可单独启用)
QWEN_API_KEY=your_qwen_api_key
QWEN_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1

# ========================================
# 可选配置（数据源凭证）
# ========================================

# 国家统计局 (NBS) - 三选一即可，缺失时将平滑降级为使用公开样例数据
# 优先推荐填写浏览器登录后的 Cookie，其次为 Token，最后才是账号密码登录尝试
NBS_COOKIE=your_nbs_cookie
NBS_ACCOUNT=your_nbs_account
NBS_PASSWORD=your_nbs_password
NBS_TOKEN=your_nbs_token

# 配置完成后可运行：
# npx tsx src/server/minimum-deployment-report.ts
# 用于验证"至少一个模型 API Key + 可选 NBS 凭证"是否满足最小部署条件

# ========================================
# 生产环境部署配置
# ========================================
# NODE_ENV=production
# CORS_ORIGIN=http://your-server-ip:3001,http://localhost:3001
# 或者使用通配符允许所有来源（仅限内网部署场景）：
# CORS_ORIGIN=*


